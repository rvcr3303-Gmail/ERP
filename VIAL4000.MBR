          05 VIAL4000-INPUT.
             10 VIAL4000-ORIGEM                  PIC X(10).
             10 VIAL4000-PGMID                   PIC X(10).
             10 VIAL4000-TRANSACCAO.
                15 VIAL4000-APLIC                PIC X(02).
                15 VIAL4000-OPCAO                PIC X(03).
                15 VIAL4000-ACCAO                PIC X(01).
                   88 VIAL4000-VISUALIZACAO      VALUE 'V'.
                   88 VIAL4000-CRIACAO           VALUE 'I' 'C'.
                   88 VIAL4000-MODIFICACAO       VALUE 'M'.
                   88 VIAL4000-ANULACAO          VALUE 'E' 'A'.
                   88 VIAL4000-CONSULTALISTA     VALUE 'L'.
             10 VIAL4000-PEDIDO-DADOS            PIC X(01).
                88 VIAL4000-PEDIDO-SIM           VALUE 'S'.
                88 VIAL4000-PEDIDO-NAO           VALUE 'N'.
             10 VIAL4000-NR-ELECTRONICO.
                15 VIAL4000-CUTILIZA             PIC X(20).
                15 VIAL4000-DATA-PROCESSO        PIC X(10).
                15 VIAL4000-NR-SEQUENCIA         PIC 9(10).

             10 VIAL4000-MSG-SIZE                PIC 9(10).
      ******* ID DO LOCAL
             10 VIAL4000-COD-LOCAL               PIC X(60).
                 10 VIAL4000-FILLER-INPUT            PIC X(140).

             10 VIAL4000-MENSAGEM-INPUT          PIC X(11500).

          05 VIAL4000-OUTPUT.
             10 VIAL4000-HEADER-OUTPUT.
                15 VIAL4000-INFORMACAO-AUXILIAR.
                   20 VIAL4000-OCORRENCIAS       PIC 9(05).
                   20 VIAL4000-LENGTH-MSG        PIC 9(05).
                   20 VIAL4000-NR-CAMPOS         PIC 9(05).
                15 VIAL4000-AREA-ERROS.
                          20 VIAL4000-IND-ERROS         PIC X(02).
                      88 VIAL4000-SEM-ERROS          VALUE 'OK'.
                      88 VIAL4000-ERROS-FUNCAO       VALUE 'FU'.
                      88 VIAL4000-FIM-CONSULTA       VALUE 'FC'.
                      88 VIAL4000-ERROS-ARQ          VALUE 'AT'.
                      88 VIAL4000-ERROS-PIN          VALUE 'PN'.
                      88 VIAL4000-ERROS-INF          VALUE 'IF'.
                      88 VIAL4000-ABEND-DB2          VALUE 'A2'.
                      88 VIAL4000-ERROS-VALIDOS
                                     VALUE 'FU', 'OK', 'PN', 'FC'.
                           20 VIAL4000-CAPLIC    PIC  X(02).
                           20 VIAL4000-NRERRO    PIC  9(04).
                   20 VIAL4000-ERRMSG            PIC  X(100).
