      *--------------------------------------------------------------
       COPY VIAL0015.
       COPY VIAW0005.
       COPY VIAK0001.
       COPY VIAK0002.
       COPY TGCL1000.
       COPY TGCL2000.
       COPY TGCK0002.
      *
      *
      *--------------------------------------------------------------
      *            CONSTANTES
      *--------------------------------------------------------------
       01  WS-CONSTANTES.
           05 WS-PROGNAME  PIC X(08) VALUE 'COI63203'.
           05 CON-CTABELA-CTIPO    PIC X(05) VALUE 'CO155'.
           05 CON-CTABELA-CTIPDOC  PIC X(05) VALUE 'CO020'.
           05 CON-CTABELA-ISTATUS  PIC X(05) VALUE 'CO013'.
           05 CON-CTABELA-CPAIS  PIC X(05) VALUE 'AR047'.
           05 CON-CTABELA-CCAE  PIC X(05) VALUE 'CO016'.
           05 CON-CTABELA-CCLASS  PIC X(05) VALUE 'CO017'.
           05 CON-CTABELA-CFORMAJ  PIC X(05) VALUE 'CO018'.
           05 CON-CTABELA-CCONTACTO  PIC X(05) VALUE 'GR012'.
           05 CON-CTABELA-CIDIOMA  PIC X(05) VALUE 'AR001'.
           05 CON-CTABELA-CMOEDA   PIC X(05) VALUE 'AR041'.
      *--------------------------------------------------------------
      *            VARIAVEIS
      *--------------------------------------------------------------
       01  WS-VARIAVEIS.
           05 WS-CTABELA                   PIC X(05) VALUE SPACES.
           05 WS-CCOD                      PIC X(40) VALUE SPACES.
           05 WS-C2COD                     PIC X(40) VALUE SPACES.
      *--------------------------------------------------------------
       01  FILLER                        PIC X(40) VALUE
           'FIM DA WORKING-STORAGE COI63203         '.
