      ******************************************************************
      *                INSERT VIAT1200_BFLOGB                          *
      ******************************************************************
           EXEC SQL
              INSERT INTO VIAT1200_BFLOGB
                     (CTRAN      ,
                      ORIGEM     ,
                      CALLERID   ,
                      CAPLIC     ,
                      COPCAO     ,
                      CACCAO     ,
                      CUTILIZAI  ,
                      DPROCI     ,
                      NRSEQI     ,
                      IPEDDADOS  ,
                      ISIMUL     ,
                      XLIVRE1    ,
                      XMSGIN     ,
                      CUTILIZAO  ,
                      DPROCO     ,
                      NRSEQO     ,
                      INDERROS   ,
                      NRERRO     ,
                      CONTEXT1   ,
                      CONTEXT2   ,
                      NOCCURS    ,
                      LENGTHMSG  ,
                      NRCAMPOS   ,
                      XLIVRE2    ,
                      XMSGOUT    ,
                      HTIMEST)
              VALUES (:VIAD1200-CTRAN      ,
                      :VIAD1200-ORIGEM     ,
                      :VIAD1200-CALLERID   ,
                      :VIAD1200-CAPLIC     ,
                      :VIAD1200-COPCAO     ,
                      :VIAD1200-CACCAO     ,
                      :VIAD1200-CUTILIZAI  ,
                      :VIAD1200-DPROCI     ,
                      :VIAD1200-NRSEQI     ,
                      :VIAD1200-IPEDDADOS  ,
                      :VIAD1200-ISIMUL     ,
                      :VIAD1200-XLIVRE1    ,
                      :VIAD1200-XMSGIN-TEXT     ,
                      :VIAD1200-CUTILIZAO  ,
                      :VIAD1200-DPROCO     ,
                      :VIAD1200-NRSEQO     ,
                      :VIAD1200-INDERROS   ,
                      :VIAD1200-NRERRO     ,
                      :VIAD1200-CONTEXT1   ,
                      :VIAD1200-CONTEXT2   ,
                      :VIAD1200-NOCCURS    ,
                      :VIAD1200-LENGTHMSG  ,
                      :VIAD1200-NRCAMPOS   ,
                      :VIAD1200-XLIVRE2    ,
                      :VIAD1200-XMSGOUT-TEXT    ,
                      CURRENT_TIMESTAMP)
           END-EXEC.
