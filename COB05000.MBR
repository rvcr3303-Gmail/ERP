           EXEC SQL
               FETCH CURCOT36
               INTO :COCD3606-NIDPROJECTO
                  , :COCD3606-CMOEDA
                  , :COCD3606-DBEGINDATE
                  , :COCD3606-NBUDGET
                  , :COCD3606-NBUDCTRV
           END-EXEC.

           PERFORM 9020-DB2CHECK
              THRU 9029-DB2CHECK-EXIT.

           MOVE SQLCODE                TO WS-STATUS-COT36.

           IF  NOT DB2-OK
           AND NOT DB2-NOTFND
             SET  VIAW0030-DB2-ERROR          TO TRUE
             SET  VIAW0012-ABEND-DB2          TO TRUE
             MOVE WS-PROGNAME                 TO VIAW0030-PGMNAME
             MOVE VIAL0015-CALLER-ID          TO VIAW0030-PARAGRAPH-NAME
             MOVE VIAW0012-TABLE-NAME         TO VIAW0030-TABLE-NAME
             MOVE VIAW0012-SQLCODE            TO VIAW0030-SQLCODE
             MOVE SPACES                      TO VIAW0030-ACCESS-KEY
             MOVE 'ERRO NO FETCH DO CURSOR'   TO VIAW0030-DESC1
             MOVE 'CURCOT36'                  TO VIAW0030-DESC2
             PERFORM VIAP0030-ESCREVE-SPOOL
                THRU VIAP0030-ESCREVE-SPOOL-EXIT
             PERFORM 9990-ABEND
                THRU 9999-ABEND-EXIT
           END-IF.

       2200-FETCH-CURCOT36-EXIT.
           EXIT.
      ******************************************************************
      *                   PROCESSA CURCOT36.
      ******************************************************************
       2300-PROCESSA-CURCOT36.

           IF VIAL0015-DEBUG-SIM
              MOVE '2300-PROCESSA-CURCOT36  ' TO VIAL0015-CALLER-ID
              PERFORM VIAP0015-TRATA-DEBUG
                 THRU VIAP0015-TRATA-DEBUG-EXIT
           END-IF.

           PERFORM 2400-TRATA-CURCOT36
              THRU 2400-TRATA-CURCOT36-EXIT.

           IF ATCK0001-SEM-ERROS
              PERFORM 2200-FETCH-CURCOT36
                 THRU 2200-FETCH-CURCOT36-EXIT
           END-IF.

       2300-PROCESSA-CURCOT36-EXIT.
           EXIT.
      ******************************************************************
      *                   TRATA CURCOT36
      ******************************************************************
       2400-TRATA-CURCOT36.

           IF VIAL0015-DEBUG-SIM
              MOVE '2400-TRATA-CURCOT36     ' TO VIAL0015-CALLER-ID
              PERFORM VIAP0015-TRATA-DEBUG
                 THRU VIAP0015-TRATA-DEBUG-EXIT
           END-IF.

           INITIALIZE EXCL0200-DATA    REPLACING NUMERIC BY ZEROES
                                         ALPHANUMERIC BY SPACES.

           MOVE COCD3606-CMOEDA        TO EXCL0200-EXMOEDORIG
           MOVE AQCW0100-AT-CMOE       TO EXCL0200-EXMOEDDEST

           IF COCD3606-DBEGINDATE NOT EQUAL COCK0002-DATA-MIN
             MOVE COCD3606-DBEGINDATE    TO AQCW0005-DTX10
             PERFORM AQCP0005-CONV-DT10INDT8
                THRU AQCP0005-CONV-DT10INDT8-EXIT
             MOVE AQCW0005-DT98          TO EXCL0200-EXDATA
           ELSE
             MOVE AQCW0100-AT-DTOP       TO EXCL0200-EXDATA
           END-IF

           MOVE ZEROES                 TO EXCL0200-EXHORA
           MOVE EXCK0002-CAMB-COMERC   TO EXCL0200-EXTIPOCAMB

           PERFORM 2420-OBT-CAMB-PROJ
              THRU 2420-OBT-CAMB-PROJ-EXIT

           IF ATCK0001-SEM-ERROS
             PERFORM 2435-ACT-CTRVLR-PROJ
                THRU 2435-ACT-CTRVLR-PROJ-EXIT
           END-IF.

       2400-TRATA-CURCOT36-EXIT.
           EXIT.
      ******************************************************************
      *                   OBTEM CAMBIO OPORTUNIDADES
      ******************************************************************
       2420-OBT-CAMB-OP.

           IF VIAL0015-DEBUG-SIM
              MOVE '2420-OBT-CAMB-OP    ' TO VIAL0015-CALLER-ID
              PERFORM VIAP0015-TRATA-DEBUG
                 THRU VIAP0015-TRATA-DEBUG-EXIT
           END-IF.

            PERFORM CALL-EXR00200
               THRU CALL-EXR00200-EXIT.

            IF ETCL0002-SEM-ERROS
              CONTINUE
            ELSE
              SET ATCK0001-ABEND TO TRUE
            END-IF.

       2420-OBT-CAMB-OP-EXIT.
           EXIT.
      ******************************************************************
      *                   ACTUALIZA CONTRAVALOR DAS OPORTUNIDADES
      ******************************************************************
       2435-ACT-CTRVLR-OP.

           IF VIAL0015-DEBUG-SIM
              MOVE '2435-ACT-CTRVLR-OP     ' TO VIAL0015-CALLER-ID
              PERFORM VIAP0015-TRATA-DEBUG
                 THRU VIAP0015-TRATA-DEBUG-EXIT
           END-IF.
      *
           COMPUTE COCD0604-MCTRVLR  = COCD0604-NVALOR *
                   EXCL0200-EXVALOR1

           EXEC SQL
             UPDATE COVT0604_OPPORTUNITIES
                SET MCTRVLR = :COCD0604-MCTRVLR
              WHERE CURRENT OF CURCOT06
           END-EXEC.

           PERFORM 9020-DB2CHECK
              THRU 9029-DB2CHECK-EXIT.

           EVALUATE TRUE
             WHEN DB2-OK
               CONTINUE
             WHEN OTHER
               PERFORM 9990-ABEND
                  THRU 9999-ABEND-EXIT
           END-EVALUATE.
      *
       2435-ACT-CTRVLR-OP-EXIT.
           EXIT.
      ******************************************************************
      *                   CLOSE CURCOT06
      ******************************************************************
       2500-CLOSE-CURCOT06.

           IF VIAL0015-DEBUG-SIM
              MOVE '2500-CLOSE-CURCOT06     ' TO VIAL0015-CALLER-ID
              PERFORM VIAP0015-TRATA-DEBUG
                 THRU VIAP0015-TRATA-DEBUG-EXIT
           END-IF.

           EXEC SQL
                CLOSE CURCOT06
           END-EXEC.

           PERFORM 9020-DB2CHECK
              THRU 9029-DB2CHECK-EXIT.

           IF  NOT DB2-OK
           AND NOT DB2-NOTFND
             SET  VIAW0030-DB2-ERROR         TO TRUE
             SET  VIAW0012-ABEND-DB2         TO TRUE
             MOVE WS-PROGNAME                TO VIAW0030-PGMNAME
             MOVE VIAL0015-CALLER-ID         TO VIAW0030-PARAGRAPH-NAME
             MOVE VIAW0012-TABLE-NAME        TO VIAW0030-TABLE-NAME
             MOVE VIAW0012-SQLCODE           TO VIAW0030-SQLCODE
             MOVE SPACES                     TO VIAW0030-ACCESS-KEY
             MOVE 'ERRO NO CLOSE DO CURSOR'  TO VIAW0030-DESC1
             MOVE 'CURCOT06'                 TO VIAW0030-DESC2
             PERFORM VIAP0030-ESCREVE-SPOOL
                THRU VIAP0030-ESCREVE-SPOOL-EXIT
             PERFORM 9990-ABEND
                THRU 9999-ABEND-EXIT
           END-IF.

       2500-CLOSE-CURCOT06-EXIT.
           EXIT.
      ******************************************************************
      *                   OBTEM CAMBIO PROJECTOS
      ******************************************************************
       2420-OBT-CAMB-PROJ.

           IF VIAL0015-DEBUG-SIM
              MOVE '2420-OBT-CAMB-PROJ  ' TO VIAL0015-CALLER-ID
              PERFORM VIAP0015-TRATA-DEBUG
                 THRU VIAP0015-TRATA-DEBUG-EXIT
           END-IF.

            PERFORM CALL-EXR00200
               THRU CALL-EXR00200-EXIT.

            IF ETCL0002-SEM-ERROS
              CONTINUE
            ELSE
              SET ATCK0001-ABEND TO TRUE
            END-IF.

       2420-OBT-CAMB-PROJ-EXIT.
           EXIT.
      ******************************************************************
      *                   ACTUALIZA CONTRAVALOR DOS PROJECTOS
      ******************************************************************
       2435-ACT-CTRVLR-PROJ.

           IF VIAL0015-DEBUG-SIM
              MOVE '2435-ACT-CTRVLR-PROJ   ' TO VIAL0015-CALLER-ID
              PERFORM VIAP0015-TRATA-DEBUG
                 THRU VIAP0015-TRATA-DEBUG-EXIT
           END-IF.
      *
           COMPUTE COCD3606-NBUDCTRV = COCD3606-NBUDGET *
                   EXCL0200-EXVALOR1

           EXEC SQL
             UPDATE COVT3606_PROJECTS
                SET NBUDCTRV = :COCD3606-NBUDCTRV
              WHERE CURRENT OF CURCOT36
           END-EXEC.

           PERFORM 9020-DB2CHECK
              THRU 9029-DB2CHECK-EXIT.

           EVALUATE TRUE
             WHEN DB2-OK
               CONTINUE
             WHEN OTHER
               PERFORM 9990-ABEND
                  THRU 9999-ABEND-EXIT
           END-EVALUATE.
      *
       2435-ACT-CTRVLR-PROJ-EXIT.
           EXIT.
      ******************************************************************
      *                   CLOSE CURCOT36
      ******************************************************************
       2500-CLOSE-CURCOT36.

           IF VIAL0015-DEBUG-SIM
              MOVE '2500-CLOSE-CURCOT36     ' TO VIAL0015-CALLER-ID
              PERFORM VIAP0015-TRATA-DEBUG
                 THRU VIAP0015-TRATA-DEBUG-EXIT
           END-IF.

           EXEC SQL
                CLOSE CURCOT36
           END-EXEC.

           PERFORM 9020-DB2CHECK
              THRU 9029-DB2CHECK-EXIT.

           IF  NOT DB2-OK
           AND NOT DB2-NOTFND
             SET  VIAW0030-DB2-ERROR         TO TRUE
             SET  VIAW0012-ABEND-DB2         TO TRUE
             MOVE WS-PROGNAME                TO VIAW0030-PGMNAME
             MOVE VIAL0015-CALLER-ID         TO VIAW0030-PARAGRAPH-NAME
             MOVE VIAW0012-TABLE-NAME        TO VIAW0030-TABLE-NAME
             MOVE VIAW0012-SQLCODE           TO VIAW0030-SQLCODE
             MOVE SPACES                     TO VIAW0030-ACCESS-KEY
             MOVE 'ERRO NO CLOSE DO CURSOR'  TO VIAW0030-DESC1
             MOVE 'CURCOT36'                 TO VIAW0030-DESC2
             PERFORM VIAP0030-ESCREVE-SPOOL
                THRU VIAP0030-ESCREVE-SPOOL-EXIT
             PERFORM 9990-ABEND
                THRU 9999-ABEND-EXIT
           END-IF.

       2500-CLOSE-CURCOT36-EXIT.
           EXIT.
      ******************************************************************
      *                     3000-FIM-PROGRAMA.
      ******************************************************************
       3000-FIM-PROGRAMA.

           IF VIAL0015-DEBUG-SIM
              MOVE '3000-FIM-PROGRAMA       ' TO VIAL0015-CALLER-ID
              PERFORM VIAP0015-TRATA-DEBUG
                 THRU VIAP0015-TRATA-DEBUG-EXIT
           END-IF.

           IF NOT ATCK0001-SEM-ERROS
              EXEC SQL ROLLBACK END-EXEC
           ELSE
              EXEC SQL COMMIT   END-EXEC
           END-IF.

           IF NOT ATCK0001-SEM-ERROS
             MOVE '*** ERRO COB05000  ***'   TO VIAL0015-CALLER-ID
             MOVE 'ATCK0001-RCODE '        TO VIAL0015-CAMPO-NM(1)
             MOVE ATCK0001-RCODE           TO VIAL0015-CAMPO-VLR(1)
             PERFORM VIAP0015-TRATA-DEBUG
                THRU VIAP0015-TRATA-DEBUG-EXIT
           END-IF.

           PERFORM AQCP0009-TRATA-RCODE
              THRU AQCP0009-TRATA-RCODE-EXIT.

           PERFORM AQCP0002-TRATA-SYNCPOINT
              THRU AQCP0002-TRATA-SYNCPOINT-EXIT.

           IF AQCW0009-SEM-ERROS
              PERFORM AQCP0100-REG-FIM
                 THRU AQCP0100-REG-FIM-EXIT
           END-IF.

       3000-FIM-PROGRAMA-EXIT.
           EXIT.
      ******************************************************************
           COPY VIAP0015.
           COPY AQCP0109.
           COPY AQCP0009.
           COPY VIAP0030.
           COPY EXCP0200.

           EXEC SQL INCLUDE VIAP9999 END-EXEC.
           EXEC SQL INCLUDE AQCP0002 END-EXEC.
           EXEC SQL INCLUDE VIAP0012 END-EXEC.
