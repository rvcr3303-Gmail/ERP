       AQCP0099-TRATA-RCODE.
           IF AQCW0009-RCODE-INF
              SET VIAL0002-SEM-ERROS TO TRUE
           END-IF.
           IF AQCW0009-SEM-ERROS
              SET VIAL0002-SEM-ERROS TO TRUE
           END-IF.
           IF AQCW0009-RCODE-VAL
              SET VIAL0002-ERROS-FUNCAO TRUE
           END-IF.
           IF AQCW0009-RCODE-APL
              SET VIAL0002-ABEND     TO TRUE
           END-IF.
       AQCP0099-TRATA-RCODE-EXIT.
           EXIT.

