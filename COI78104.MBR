                                              COCV7811-NTAXAMOUNT4
               MOVE COCL5005-NRETAMOUNT    TO WS-NRETAMOUNT4
               MOVE COCL5005-NRETTAX       TO WS-NRETTAX4
             END-IF

           END-IF.

       2500-VALIDA-OC4-EXIT.
           EXIT.

      *--------------------------------------------------------------
      *--- 2100-VALIDA-IMPOSTO
      *--------------------------------------------------------------
       2100-VALIDA-IMPOSTO.

           IF VIAL0001-DEBUG-SIM
              MOVE '2100-VALIDA-IMPOSTO'  TO VIAL0015-CALLER-ID
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.

           INITIALIZE ETCL0002-COMMAREA  REPLACING NUMERIC BY ZEROES
                                              ALPHANUMERIC BY SPACES

           INITIALIZE ETCL0002-AREA-ERRO REPLACING NUMERIC BY ZEROES
                                              ALPHANUMERIC BY SPACES

           PERFORM ETCP0002-FORM-ONLINE-IN
              THRU ETCP0002-FORM-ONLINE-IN-EXIT


           PERFORM COCP5005-CALL-ROTINA
              THRU COCP5005-CALL-ROTINA-EXIT

           PERFORM ETCP0002-STD-END
              THRU ETCP0002-STD-END-EXIT

           IF VIAL0001-DEBUG-SIM
              MOVE '2100-VALIDA-IMPOSTO-EXIT' TO VIAL0015-CALLER-ID
              MOVE 'RESULT-I'         TO VIAL0015-CAMPO-NM(1)
              MOVE  COCL5005-RESULT-I TO VIAL0015-CAMPO-VLR(1)
              MOVE 'RESULT-F'         TO VIAL0015-CAMPO-NM(2)
              MOVE  COCL5005-RESULT-F TO VIAL0015-CAMPO-VLR(2)
              MOVE 'COCL5005-CPAIS'      TO VIAL0015-CAMPO-NM(3)
              MOVE  COCL5005-CPAIS       TO VIAL0015-CAMPO-VLR(3)
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.

       2100-VALIDA-IMPOSTO-EXIT.
           EXIT.

      *--------------------------------------------------------------
      *                   2200-INSERE-DADOS
      *--------------------------------------------------------------
       2200-INSERE-DADOS.

           IF VIAL0001-DEBUG-SIM
              MOVE '2200-INSERE-DADOS' TO VIAL0015-CALLER-ID
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.

      *-------------------------------------*
      *--- ESCREVE A PRIMEIRA OCORRENCIA ---*
      *-------------------------------------*
           IF  VIAL0002-SEM-ERROS
           AND COCV7810-NTOTALAMOUNT1 NOT EQUAL ZEROS
      *--- OBTEM A PROXIMA SEQUENCIA DO PROJECTO
               PERFORM 2600-BUSCA-SEQ
                  THRU 2600-BUSCA-SEQ-EXIT
               MOVE COCV7810-NIDPROJECTO      TO COCD5012-NIDPROJECTO
               MOVE COCV7810-GCLIENTE         TO COCD5012-GCLIENTE
               MOVE VIAL0001-DATA-PROCESSO-I  TO COCD5012-DDATAINSER
               MOVE COCV7810-DDATAEMISS1      TO COCD5012-DDATAEMISS
               MOVE COCK0002-DATA-MIN         TO COCD5012-DDATAEMIS2
               MOVE COCV7810-DDATEDUE1        TO COCD5012-DDATEDUE
               MOVE COCV7810-CPRAZO1          TO COCD5012-CPRAZO
               MOVE COCV7810-NTOTALAMOUNT1    TO COCD5012-NTOTALAMOUNT
               MOVE COCV7810-NTAXAMOUNT1      TO COCD5012-NTAXAMOUNT
               MOVE WS-NRETAMOUNT1            TO COCD5012-NTOTRET
               MOVE WS-NRETTAX1               TO COCD5012-NTAXRET
               MOVE COCV7810-GDESCINVOICE1    TO COCD5012-GDESCINVOICE
               MOVE CON-0                     TO COCD5012-CSTATUS
               MOVE VIAL0001-CUTILIZA-I       TO COCD5012-CUSERID
               MOVE SPACES                    TO COCD5012-GREFINV
               MOVE COCK0002-DATA-MIN         TO COCD5012-DPAG
               MOVE COCV7810-CMOEDA           TO COCD5012-CMOEDA
               MOVE COCV7810-CIMPOSTO1        TO COCD5012-CIMPOSTO
               MOVE COCV7810-NOTAS1           TO COCD5012-NOTAS
               MOVE COCV7810-CTIPFAC1         TO COCD5012-CTIPFAC
               MOVE COCD3605-CEMPRESA         TO COCD5012-CEMPRESA
               COMPUTE COCV7811-NVALTOT1  = COCV7810-NTOTALAMOUNT1
                                          + COCV7810-NTAXAMOUNT1
               IF COCV7810-NTOTALAMOUNT1 < 0
                  MOVE COCK0002-NOTA-CREDITO   TO COCD5012-CTIPDOC
               ELSE
                  MOVE COCK0002-FACTURA        TO COCD5012-CTIPDOC
               END-IF
      *--- ESCREVE A PRIMEIRA OCORRENCIA
               PERFORM 2700-INSERT
                  THRU 2700-INSERT-EXIT
           END-IF.

      *------------------------------------*
      *--- ESCREVE A SEGUNDA OCORRENCIA ---*
      *------------------------------------*
           IF  VIAL0002-SEM-ERROS
           AND COCV7810-NTOTALAMOUNT2 NOT EQUAL ZEROS
      *--- OBTEM A PROXIMA SEQUENCIA DO PROJECTO
               PERFORM 2600-BUSCA-SEQ
                  THRU 2600-BUSCA-SEQ-EXIT
               MOVE COCV7810-NIDPROJECTO      TO COCD5012-NIDPROJECTO
               MOVE COCV7810-GCLIENTE         TO COCD5012-GCLIENTE
               MOVE VIAL0001-DATA-PROCESSO-I  TO COCD5012-DDATAINSER
               MOVE COCV7810-DDATAEMISS2      TO COCD5012-DDATAEMISS
               MOVE COCK0002-DATA-MIN         TO COCD5012-DDATAEMIS2
               MOVE COCV7810-DDATEDUE2        TO COCD5012-DDATEDUE
               MOVE COCV7810-CPRAZO2          TO COCD5012-CPRAZO
               MOVE COCV7810-NTOTALAMOUNT2    TO COCD5012-NTOTALAMOUNT
               MOVE COCV7810-NTAXAMOUNT2      TO COCD5012-NTAXAMOUNT
               MOVE WS-NRETAMOUNT2            TO COCD5012-NTOTRET
               MOVE WS-NRETTAX2               TO COCD5012-NTAXRET
               MOVE COCV7810-GDESCINVOICE2    TO COCD5012-GDESCINVOICE
               MOVE CON-0                     TO COCD5012-CSTATUS
               MOVE VIAL0001-CUTILIZA-I       TO COCD5012-CUSERID
               MOVE SPACES                    TO COCD5012-GREFINV
               MOVE COCK0002-DATA-MIN         TO COCD5012-DPAG
               MOVE COCV7810-CMOEDA           TO COCD5012-CMOEDA
               MOVE COCV7810-CIMPOSTO2        TO COCD5012-CIMPOSTO
               MOVE COCV7810-NOTAS2           TO COCD5012-NOTAS
               MOVE COCV7810-CTIPFAC2         TO COCD5012-CTIPFAC
               MOVE COCD3605-CEMPRESA         TO COCD5012-CEMPRESA
               COMPUTE COCV7811-NVALTOT2  = COCV7810-NTOTALAMOUNT2
                                          + COCV7810-NTAXAMOUNT2
               IF COCV7810-NTOTALAMOUNT2 < 0
                  MOVE COCK0002-NOTA-CREDITO   TO COCD5012-CTIPDOC
               ELSE
                  MOVE COCK0002-FACTURA        TO COCD5012-CTIPDOC
               END-IF
      *--- ESCREVE A PRIMEIRA OCORRENCIA
               PERFORM 2700-INSERT
                  THRU 2700-INSERT-EXIT
           END-IF.

      *-------------------------------------*
      *--- ESCREVE A TERCEIRA OCORRENCIA ---*
      *-------------------------------------*
           IF  VIAL0002-SEM-ERROS
           AND COCV7810-NTOTALAMOUNT3 NOT EQUAL ZEROS
      *--- OBTEM A PROXIMA SEQUENCIA DO PROJECTO
               PERFORM 2600-BUSCA-SEQ
                  THRU 2600-BUSCA-SEQ-EXIT
               MOVE COCV7810-NIDPROJECTO      TO COCD5012-NIDPROJECTO
               MOVE COCV7810-GCLIENTE         TO COCD5012-GCLIENTE
               MOVE VIAL0001-DATA-PROCESSO-I  TO COCD5012-DDATAINSER
               MOVE COCV7810-DDATAEMISS3      TO COCD5012-DDATAEMISS
               MOVE COCK0002-DATA-MIN         TO COCD5012-DDATAEMIS2
               MOVE COCV7810-DDATEDUE3        TO COCD5012-DDATEDUE
               MOVE COCV7810-CPRAZO3          TO COCD5012-CPRAZO
               MOVE COCV7810-NTOTALAMOUNT3    TO COCD5012-NTOTALAMOUNT
               MOVE COCV7810-NTAXAMOUNT3      TO COCD5012-NTAXAMOUNT
               MOVE WS-NRETAMOUNT3            TO COCD5012-NTOTRET
               MOVE WS-NRETTAX3               TO COCD5012-NTAXRET
               MOVE COCV7810-GDESCINVOICE3    TO COCD5012-GDESCINVOICE
               MOVE CON-0                     TO COCD5012-CSTATUS
               MOVE VIAL0001-CUTILIZA-I       TO COCD5012-CUSERID
               MOVE SPACES                    TO COCD5012-GREFINV
               MOVE COCK0002-DATA-MIN         TO COCD5012-DPAG
               MOVE COCV7810-CMOEDA           TO COCD5012-CMOEDA
               MOVE COCV7810-CIMPOSTO3        TO COCD5012-CIMPOSTO
               MOVE COCV7810-NOTAS3           TO COCD5012-NOTAS
               MOVE COCV7810-CTIPFAC3         TO COCD5012-CTIPFAC
               MOVE COCD3605-CEMPRESA         TO COCD5012-CEMPRESA
               COMPUTE COCV7811-NVALTOT3  = COCV7810-NTOTALAMOUNT3
                                          + COCV7810-NTAXAMOUNT3
               IF COCV7810-NTOTALAMOUNT3 < 0
                  MOVE COCK0002-NOTA-CREDITO   TO COCD5012-CTIPDOC
               ELSE
                  MOVE COCK0002-FACTURA        TO COCD5012-CTIPDOC
               END-IF
      *--- ESCREVE A PRIMEIRA OCORRENCIA
               PERFORM 2700-INSERT
                  THRU 2700-INSERT-EXIT
           END-IF.

      *-----------------------------------*
      *--- ESCREVE A QUARTA OCORRENCIA ---*
      *-----------------------------------*
           IF  VIAL0002-SEM-ERROS
           AND COCV7810-NTOTALAMOUNT4 NOT EQUAL ZEROS
      *--- OBTEM A PROXIMA SEQUENCIA DO PROJECTO
               PERFORM 2600-BUSCA-SEQ
                  THRU 2600-BUSCA-SEQ-EXIT
               MOVE COCV7810-NIDPROJECTO      TO COCD5012-NIDPROJECTO
               MOVE COCV7810-GCLIENTE         TO COCD5012-GCLIENTE
               MOVE VIAL0001-DATA-PROCESSO-I  TO COCD5012-DDATAINSER
               MOVE COCV7810-DDATAEMISS4      TO COCD5012-DDATAEMISS
               MOVE COCK0002-DATA-MIN         TO COCD5012-DDATAEMIS2
               MOVE COCV7810-DDATEDUE4        TO COCD5012-DDATEDUE
               MOVE COCV7810-CPRAZO4          TO COCD5012-CPRAZO
               MOVE COCV7810-NTOTALAMOUNT4    TO COCD5012-NTOTALAMOUNT
               MOVE COCV7810-NTAXAMOUNT4      TO COCD5012-NTAXAMOUNT
               MOVE WS-NRETAMOUNT4            TO COCD5012-NTOTRET
               MOVE WS-NRETTAX4               TO COCD5012-NTAXRET
               MOVE COCV7810-GDESCINVOICE4    TO COCD5012-GDESCINVOICE
               MOVE CON-0                     TO COCD5012-CSTATUS
               MOVE VIAL0001-CUTILIZA-I       TO COCD5012-CUSERID
               MOVE SPACES                    TO COCD5012-GREFINV
               MOVE COCK0002-DATA-MIN         TO COCD5012-DPAG
               MOVE COCV7810-CMOEDA           TO COCD5012-CMOEDA
               MOVE COCV7810-CIMPOSTO4        TO COCD5012-CIMPOSTO
               MOVE COCV7810-NOTAS4           TO COCD5012-NOTAS
               MOVE COCV7810-CTIPFAC4         TO COCD5012-CTIPFAC
               MOVE COCD3605-CEMPRESA         TO COCD5012-CEMPRESA
               COMPUTE COCV7811-NVALTOT4  = COCV7810-NTOTALAMOUNT4
                                          + COCV7810-NTAXAMOUNT4
               IF COCV7810-NTOTALAMOUNT4 < 0
                  MOVE COCK0002-NOTA-CREDITO   TO COCD5012-CTIPDOC
               ELSE
                  MOVE COCK0002-FACTURA        TO COCD5012-CTIPDOC
               END-IF
      *--- ESCREVE A PRIMEIRA OCORRENCIA
               PERFORM 2700-INSERT
                  THRU 2700-INSERT-EXIT
           END-IF.


       2299-INSERE-DADOS-EXIT.
           EXIT.
      *--------------------------------------------------------------
      * ESCREVE FACTURA
      *--------------------------------------------------------------
       2700-INSERT.

           IF VIAL0001-DEBUG-SIM
              MOVE '2700-INSERT      ' TO VIAL0015-CALLER-ID
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.

           IF VIAL0002-SEM-ERROS

              EXEC SQL
                   INSERT INTO COVT5012_INVOICES
                   (
                      NIDINVOICE
                    , NIDPROJECTO
                    , GCLIENTE
                    , DDATAINSER
                    , DDATAEMISS
                    , DDATAEMIS2
                    , DDATEDUE
                    , CPRAZO
                    , NTOTALAMOUNT
                    , NTAXAMOUNT
                    , GDESCINVOICE
                    , CSTATUS
                    , CUSERID
                    , HTIMEST
                    , GREFINV
                    , DPAG
                    , CTIPDOC
                    , CMOEDA
                    , CIMPOSTO
                    , NOTAS
                    , CTIPFAC
                    , NTOTRET
                    , NTAXRET
                    , CEMPRESA
                   )
                   VALUES (
                          :COCD5012-NIDINVOICE
                        , :COCD5012-NIDPROJECTO
                        , :COCD5012-GCLIENTE
                        , :COCD5012-DDATAINSER
                        , :COCD5012-DDATAEMISS
                        , :COCD5012-DDATAEMIS2
                        , :COCD5012-DDATEDUE
                        , :COCD5012-CPRAZO
                        , :COCD5012-NTOTALAMOUNT
                        , :COCD5012-NTAXAMOUNT
                        , :COCD5012-GDESCINVOICE
                        , :COCD5012-CSTATUS
                        , :COCD5012-CUSERID
                        ,  CURRENT TIMESTAMP
                        , :COCD5012-GREFINV
                        , :COCD5012-DPAG
                        , :COCD5012-CTIPDOC
                        , :COCD5012-CMOEDA
                        , :COCD5012-CIMPOSTO
                        , :COCD5012-NOTAS
                        , :COCD5012-CTIPFAC
                        , :COCD5012-NTOTRET
                        , :COCD5012-NTAXRET
                        , :COCD5012-CEMPRESA
                   )
              END-EXEC

              MOVE CON-COVT5012               TO VIAL0002-TABLE-NAME

              PERFORM 9020-DB2CHECK
                 THRU 9029-DB2CHECK-EXIT

              IF VIAL0002-SEM-ERROS
                 IF DB2-DUPREC
                    MOVE VIAK0002-ERROS-FUNCAO
                      TO VIAL0002-IND-ERROS
                      MOVE COCK0002-STATUS-ACTIVO
                        TO COCV7811-NIDPROJECTO-S
                      MOVE COCK0001-NIDPROJECTO-A-EXISTS
                        TO COCV7811-NIDPROJECTO-MSG
                      MOVE COCK0002-CAPLIC
                        TO COCV7811-NIDPROJECTO-CAPLIC
                 ELSE
                    IF NOT DB2-OK
                       MOVE VIAK0002-ABEND-DB2
                         TO VIAL0002-IND-ERROS
                       MOVE VIAK0001-ERRO-DB2
                         TO VIAL0002-COD-ERRO-GRAVE
                    END-IF
                 END-IF
              END-IF
           END-IF.

       2700-INSERT-EXIT.
           EXIT.

      *--------------------------------------------------------------
      * BUSCA A PROXIMA SEQUENCIA DO PROJECTO
      *--------------------------------------------------------------
       2600-BUSCA-SEQ.

           IF VIAL0001-DEBUG-SIM
              MOVE '2600-BUSCA-SEQ   ' TO VIAL0015-CALLER-ID
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.

           MOVE COCV7810-NIDPROJECTO  TO COCD5012-NIDPROJECTO.

           EXEC SQL
                SELECT  IFNULL(MAX(NIDINVOICE), 0) + 1
                  INTO :COCD5012-NIDINVOICE
                  FROM  COVT5012_INVOICES
                 WHERE  NIDPROJECTO = :COCD5012-NIDPROJECTO
           END-EXEC.

           MOVE CON-COVT5012  TO VIAL0002-TABLE-NAME.
           PERFORM 9020-DB2CHECK
              THRU 9029-DB2CHECK-EXIT.

           IF VIAL0002-SEM-ERROS
              CONTINUE
           ELSE
              MOVE 1                       TO COCD5012-NIDINVOICE
           END-IF.

       2600-BUSCA-SEQ-EXIT.
           EXIT.
      *--------------------------------------------------------------
      *            3000-FINAL-PROGRAMA
      *--------------------------------------------------------------
       3000-FINAL-PROGRAMA.

           IF VIAL0001-DEBUG-SIM
              MOVE '3000-FINAL-PROGRAMA' TO VIAL0015-CALLER-ID
              PERFORM VIAP0016-TRATA-DEBUG
                 THRU VIAP0016-TRATA-DEBUG-EXIT
           END-IF.

           MOVE COCV7811-MSG         TO VIAL0001-MENSAGEM-OUTPUT.
           MOVE COCV7811-LENGTH      TO VIAL0001-LENGTH-MSG.
           MOVE COCV7811-NR-CAMPOS   TO VIAL0001-NR-CAMPOS.
           MOVE ZEROES               TO VIAL0001-OCORRENCIAS.

       3099-FINAL-PROGRAMA-EXIT.
           EXIT.
      *==============================================================
           EXEC SQL INCLUDE VIAP0003 END-EXEC.
      *==============================================================
           COPY VIAP0010.
           COPY VIAP0016.
           COPY COCP5005.
           COPY ETCP0002.
           COPY AQCP0005.
