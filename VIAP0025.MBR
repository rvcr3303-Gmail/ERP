      ******************************************************************
      *                INSERT VIAT0200_BFLOG                           *
      ******************************************************************
           EXEC SQL
              INSERT INTO VIAT0200_BFLOG
                     (CTRAN      ,
                      ORIGEM     ,
                      CALLERID   ,
                      CAPLIC     ,
                      COPCAO     ,
                      CACCAO     ,
                      CUTILIZAI  ,
                      DPROCI     ,
                      NRSEQI     ,
                      IPEDDADOS  ,
                      ISIMUL     ,
                      XLIVRE1    ,
                      XMSGIN     ,
                      CUTILIZAO  ,
                      DPROCO     ,
                      NRSEQO     ,
                      INDERROS   ,
                      NRERRO     ,
                      CONTEXT1   ,
                      CONTEXT2   ,
                      NOCCURS    ,
                      LENGTHMSG  ,
                      NRCAMPOS   ,
                      XLIVRE2    ,
                      XMSGOUT    ,
                      HTIMEST)
              VALUES (:VIAD0200-CTRAN      ,
                      :VIAD0200-ORIGEM     ,
                      :VIAD0200-CALLERID   ,
                      :VIAD0200-CAPLIC     ,
                      :VIAD0200-COPCAO     ,
                      :VIAD0200-CACCAO     ,
                      :VIAD0200-CUTILIZAI  ,
                      :VIAD0200-DPROCI     ,
                      :VIAD0200-NRSEQI     ,
                      :VIAD0200-IPEDDADOS  ,
                      :VIAD0200-ISIMUL     ,
                      :VIAD0200-XLIVRE1    ,
                      :VIAD0200-XMSGIN-TEXT     ,
                      :VIAD0200-CUTILIZAO  ,
                      :VIAD0200-DPROCO     ,
                      :VIAD0200-NRSEQO     ,
                      :VIAD0200-INDERROS   ,
                      :VIAD0200-NRERRO     ,
                      :VIAD0200-CONTEXT1   ,
                      :VIAD0200-CONTEXT2   ,
                      :VIAD0200-NOCCURS    ,
                      :VIAD0200-LENGTHMSG  ,
                      :VIAD0200-NRCAMPOS   ,
                      :VIAD0200-XLIVRE2    ,
                      :VIAD0200-XMSGOUT-TEXT    ,
                      CURRENT_TIMESTAMP)
           END-EXEC.
