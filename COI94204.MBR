                  THRU VIATP300-CONV-DATA108-EXIT
               MOVE VIATW300-DATA8 TO VIAL1000-DAT-INPUT1
               PERFORM VIAP1000-ROTINA-DATAS
                  THRU VIAP1000-EXIT

               IF    VIAL0002-SEM-ERROS
               AND   VIAL1000-DAT-RES-SEM     EQUAL CON-S
               AND ( COCV9420-C31         NOT EQUAL CON-S
               AND   COCV9420-C31         NOT EQUAL CON-F
               AND   COCV9420-C31         NOT EQUAL CON-T )
                  MOVE VIAK0002-ERROS-FUNCAO  TO VIAL0002-IND-ERROS
                  MOVE COCK0002-STATUS-ACTIVO TO COCV9421-C31-S
                  MOVE COCK0001-CAMPO-INV-SAB TO COCV9421-C31-MSG
                  MOVE COCK0002-CAPLIC        TO COCV9421-C31-CAPLIC
               END-IF

               IF    VIAL0002-SEM-ERROS
               AND   VIAL1000-DAT-RES-SEM     EQUAL CON-D
               AND ( COCV9420-C31         NOT EQUAL CON-D
               AND   COCV9420-C31         NOT EQUAL CON-F
               AND   COCV9420-C31         NOT EQUAL CON-T )
                  MOVE VIAK0002-ERROS-FUNCAO  TO VIAL0002-IND-ERROS
                  MOVE COCK0002-STATUS-ACTIVO TO COCV9421-C31-S
                  MOVE COCK0001-CAMPO-INV-DOM TO COCV9421-C31-MSG
                  MOVE COCK0002-CAPLIC        TO COCV9421-C31-CAPLIC
               END-IF

               IF    VIAL0002-SEM-ERROS
               AND   VIAL1000-DAT-RES-SEM NOT EQUAL CON-S
               AND   COCV9420-C31             EQUAL CON-S
                  MOVE VIAK0002-ERROS-FUNCAO  TO VIAL0002-IND-ERROS
                  MOVE COCK0002-STATUS-ACTIVO TO COCV9421-C31-S
                  MOVE COCK0001-CAMPO-INV-NSB TO COCV9421-C31-MSG
                  MOVE COCK0002-CAPLIC        TO COCV9421-C31-CAPLIC
               END-IF

               IF    VIAL0002-SEM-ERROS
               AND   VIAL1000-DAT-RES-SEM NOT EQUAL CON-D
               AND   COCV9420-C31             EQUAL CON-D
                  MOVE VIAK0002-ERROS-FUNCAO  TO VIAL0002-IND-ERROS
                  MOVE COCK0002-STATUS-ACTIVO TO COCV9421-C31-S
                  MOVE COCK0001-CAMPO-INV-NDM TO COCV9421-C31-MSG
                  MOVE COCK0002-CAPLIC        TO COCV9421-C31-CAPLIC
               END-IF
           END-IF.

